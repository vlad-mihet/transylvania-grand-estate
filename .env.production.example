# ─── Core ──────────────────────────────────────────────
NODE_ENV=production
PORT=3333

# Surfaced by /health/live so ops can confirm which build is running.
APP_VERSION=

# pino log level (fatal | error | warn | info | debug | trace)
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────
# Connection string for Neon / Supabase / self-hosted Postgres. Must include
# `?sslmode=require` for any managed provider.
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/tge_production?sslmode=require

# ─── Auth ──────────────────────────────────────────────
# Per-realm signing secrets. Generate each with: openssl rand -base64 48
# Each must be ≥32 characters; env validator rejects shorter values at boot.
# Admin and academy use distinct secrets so a leak of one realm cannot forge
# tokens for the other.
JWT_ADMIN_ACCESS_SECRET=CHANGE_ME_admin_access_secret
JWT_ADMIN_REFRESH_SECRET=CHANGE_ME_admin_refresh_secret
JWT_ACADEMY_ACCESS_SECRET=CHANGE_ME_academy_access_secret
JWT_ACADEMY_REFRESH_SECRET=CHANGE_ME_academy_refresh_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── CORS ──────────────────────────────────────────────
# Comma-separated origin allow-list. Startup fails if unset in production.
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://tge-admin.fly.dev

# ─── Site origins (per-brand routing) ──────────────────
# Used by SiteMiddleware to resolve X-Site from Origin/Referer when the admin
# or a marketing app hits the API without an explicit X-Site header. Comma-
# separated for multi-domain brands.
TGE_ORIGIN=https://tge.ro,https://www.tge.ro
REVERY_ORIGIN=https://revery.ro,https://www.revery.ro
ADMIN_ORIGIN=https://admin.tge.ro

# ─── Storage ───────────────────────────────────────────
# `r2` in production, `local` for dev-on-bare-metal. R2 vars are required
# when STORAGE_TYPE=r2; env validator checks this.
STORAGE_TYPE=r2
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=tge-uploads
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_PUBLIC_URL=https://uploads.yourdomain.com

# ─── Admin frontend (Next.js) ──────────────────────────
# Baked into the admin client bundle at build time.
NEXT_PUBLIC_API_URL=https://tge-api.fly.dev/api/v1

# Permanent feature flag — see the dedicated section below.
# NEXT_PUBLIC_GOOGLE_AUTH_DISABLED=

# Admin server-side (route handlers in /api/auth/*). Usually same as above.
API_URL=https://tge-api.fly.dev/api/v1

# For next/image remotePatterns — hostname only, no scheme.
API_HOSTNAME=tge-api.fly.dev

# ─── Revery frontend ──────────────────────────────────
# Public origin baked into OG/Twitter tags, canonical URLs, sitemap. No
# trailing slash. REQUIRED in production — apps/revery/src/lib/seo.ts throws
# on `next build` when NODE_ENV=production and this is unset, because an
# unguarded fallback would ship localhost URLs to crawlers.
NEXT_PUBLIC_SITE_URL=https://revery.ro

# Public origin of the Academy app, baked into Revery's footer link to the
# course catalog. Falls back to http://localhost:3053 when unset (dev only);
# leave unset locally, set explicitly in any deployed environment.
NEXT_PUBLIC_ACADEMY_URL=https://tge-academy.fly.dev

# ─── Uploads ───────────────────────────────────────────
# Max upload size in bytes (10 MB default).
MAX_FILE_SIZE=10485760

# ─── Invitation flow ───────────────────────────────────
# Public URL of the admin app. Used as the base for invitation email links
# (e.g. `${ADMIN_PUBLIC_URL}/accept-invite?token=…`) and as the OAuth
# redirect target after a successful Google sign-in.
ADMIN_PUBLIC_URL=https://admin.tge.ro

# Resend API key + verified sender. Transactional mail only — the
# invitation email is the only template in v1. Env validator requires both
# in production so a misconfigured deploy fails fast instead of silently
# dropping invitation emails.
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=TGE <no-reply@transylvaniagrandestate.ro>

# HMAC secret used to sign the OAuth `state` parameter (so an attacker can't
# replace the invitation token mid-flow). Also used to sign any other
# transient handoff tokens. Generate: openssl rand -base64 48
INVITATION_TOKEN_SECRET=CHANGE_ME_invitation_token_secret

# ─── Google OAuth ──────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=https://tge-api.fly.dev/api/v1/auth/google/callback

# ─── Webhooks ──────────────────────────────────────────
# Svix signing secret issued by Resend when you create a webhook endpoint.
# The API rejects all /webhooks/resend traffic with 503 if unset, so fail
# fast in prod \u2014 or keep blank intentionally to disable webhook handling.
RESEND_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Metrics ───────────────────────────────────────────
# Prometheus /metrics endpoint authentication. Static bearer token. If unset
# the endpoint returns 404 so metrics are fully gated off in deploys that
# don't have a scraper configured.
METRICS_BEARER_TOKEN=CHANGE_ME_metrics_bearer

# ─── Audit ─────────────────────────────────────────────
# Pepper mixed into the SHA-256 of each requester's IP before it lands in
# audit_logs.ip_hash. Raw IPs are never persisted (GDPR PII minimisation);
# the hash lets forensic queries correlate the same actor across requests
# without storing the address itself. Required in production.
# Generate: openssl rand -base64 48
AUDIT_IP_PEPPER=CHANGE_ME_audit_ip_pepper

# ─── Error reporting ───────────────────────────────────
# Sentry DSN from your project's "Client Keys" page. Leave empty to disable.
# SENTRY_TRACES_RATE: 0.0 turns off perf tracing; 1.0 traces everything (noisy
# and expensive). 0.1 is a sensible starting point.
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ─── Seed passwords (optional) ─────────────────────────
# If omitted, the seed script prints randomly-generated passwords once per
# first-time bootstrap. Pin them here for reproducible dev environments.
SEED_ADMIN_PASSWORD=
SEED_EDITOR_PASSWORD=
SEED_AGENT_PASSWORD=

# ─── Permanent feature flags ───────────────────────────
# Both default unset = feature behaves normally. The API reads these via
# FeatureFlagsService — never via ConfigService directly. Frontends mirror
# them with NEXT_PUBLIC_* counterparts (build-time, requires rebuild).
#
# EMAIL_VERIFICATION_DISABLED=1 — Academy self-service signup auto-verifies
#   new accounts and returns access + refresh tokens directly. No
#   verification email is sent and /academy/auth/resend-verification becomes
#   a silent no-op. Useful for deployments without a verified Resend domain.
# EMAIL_VERIFICATION_DISABLED=
# NEXT_PUBLIC_EMAIL_VERIFICATION_DISABLED=    # set to "true" on academy + admin frontends to match
#
# GOOGLE_AUTH_DISABLED=1 — /auth/google* and /academy/auth/google* respond
#   with 501 (code: GOOGLE_AUTH_DISABLED) regardless of GOOGLE_CLIENT_ID.
# GOOGLE_AUTH_DISABLED=
# NEXT_PUBLIC_GOOGLE_AUTH_DISABLED=           # set to "true" on academy + admin frontends to match

# ─── CRM listing sync (REBS) ───────────────────────────
# Pulls REBS property listings into REVERY/affordable hourly. Dormant until
# BOTH a key is present AND REBS_SYNC_ENABLED=1 (see RebsClient.isEnabled()).
# Set the key as a Fly secret, never in plaintext:
#   fly secrets set REBS_API_KEY=<key> REBS_SYNC_ENABLED=1 -a tge-api
# See docs/rebs-sync-go-live.md for the full cutover checklist.
REBS_API_KEY=
# Our REBS instance feed root. Override only if the instance subdomain changes.
REBS_BASE_URL=https://client-396fe343.crmrebs.com/api/public
# Master switch — leave 0 until the cutover, flip to 1 to start the hourly sync.
REBS_SYNC_ENABLED=0
