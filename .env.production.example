# Database (Neon connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/tge_production?sslmode=require

# JWT (generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://tge-admin.fly.dev

# Storage (r2 for production, local for dev)
STORAGE_TYPE=r2
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=tge-uploads
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_PUBLIC_URL=https://uploads.yourdomain.com

# API public URL (baked into admin client bundle at build time)
NEXT_PUBLIC_API_URL=https://tge-api.fly.dev/api/v1

# Admin server-side API URL
API_URL=https://tge-api.fly.dev/api/v1

# API hostname for Next.js image remote patterns
API_HOSTNAME=tge-api.fly.dev

# Public origin for the reveria app — used to build canonical URLs, hreflang
# alternates, OG/Twitter URLs, robots.txt sitemap reference, and sitemap.xml.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://reveria.ro

# Uploads
MAX_FILE_SIZE=10485760
