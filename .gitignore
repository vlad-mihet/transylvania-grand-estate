# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# nx
.nx/

# API
apps/api/uploads/

# Local tool caches
.claude/

# Stray tsc outputs next to sources (real dist goes to packages/types/dist/)
packages/types/src/**/*.js
packages/types/src/**/*.js.map
