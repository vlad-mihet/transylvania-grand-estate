# Copy to .env.local for local dev. Vercel reads its own dashboard envs in
# preview/production — keep this file aligned with what's set there.

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE=ACADEMY

# ─── Permanent feature flags ──────────────────────────────────────────────
# Mirror the API-side EMAIL_VERIFICATION_DISABLED / GOOGLE_AUTH_DISABLED
# vars. Both default to "feature on"; set to "true" to hide the related UI.
# NEXT_PUBLIC_* vars bake into the bundle at build time — toggling requires
# a rebuild (or restarting `next dev`).
#
# NEXT_PUBLIC_EMAIL_VERIFICATION_DISABLED=true — hide the "verify your email"
#   banner on /account. The register page already branches on the API
#   response shape so the "check your inbox" screen self-suppresses.
# NEXT_PUBLIC_EMAIL_VERIFICATION_DISABLED=
#
# NEXT_PUBLIC_GOOGLE_AUTH_DISABLED=true — hide the Google sign-in button on
#   /login, /register, and /accept-invite.
# NEXT_PUBLIC_GOOGLE_AUTH_DISABLED=
