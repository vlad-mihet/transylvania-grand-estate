# Copy to `apps/admin/.env` (gitignored) for local dev.
#   cp apps/admin/.env.example apps/admin/.env
# Admin reads `.env` (not `.env.local`). The API runs on :4000 in dev.

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_URL=http://localhost:4000/api/v1

# ─── Permanent feature flags ──────────────────────────────────────────────
# Mirror the API-side EMAIL_VERIFICATION_DISABLED / GOOGLE_AUTH_DISABLED vars.
# Both default to "feature on"; set to "true" to hide the related UI.
# NEXT_PUBLIC_* vars bake into the bundle at build time — toggling requires a
# rebuild (or restarting `next dev`).
#
# Hide the "verified" column, filter, badge, and resend banner in the academy
# students UI. Set when the API runs with EMAIL_VERIFICATION_DISABLED=1.
NEXT_PUBLIC_EMAIL_VERIFICATION_DISABLED=true
#
# Hide the Google sign-in button on login and accept-invite. Set when the API
# runs with GOOGLE_AUTH_DISABLED=1, or when GOOGLE_CLIENT_ID is unset.
NEXT_PUBLIC_GOOGLE_AUTH_DISABLED=true
