{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@tge/branding": ["../../packages/branding/src/index.ts"],
      "@tge/branding/*": ["../../packages/branding/src/*"],
      "@tge/types": ["../../packages/types/src/index.ts"],
      "@tge/types/*": ["../../packages/types/src/*"],
      "@tge/utils": ["../../packages/utils/src/index.ts"],
      "@tge/utils/*": ["../../packages/utils/src/*"],
      "@tge/hooks": ["../../packages/hooks/src/index.ts"],
      "@tge/hooks/*": ["../../packages/hooks/src/*"],
      "@tge/ui": ["../../packages/ui/src/index.ts"],
      "@tge/ui/*": ["../../packages/ui/src/*"],
      "@tge/i18n": ["../../packages/i18n/src/index.ts"],
      "@tge/i18n/*": ["../../packages/i18n/src/*"],
      "@tge/tailwind-config": ["../../packages/tailwind-config/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../../packages/*/src/**/*.ts",
    "../../packages/*/src/**/*.tsx"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
