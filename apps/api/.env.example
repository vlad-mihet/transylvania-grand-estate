# Copy to `apps/api/.env` (gitignored) for local dev.
#   cp apps/api/.env.example apps/api/.env
# Values below are safe dev defaults; rotate every secret before production
# (see .env.production.example at the repo root).

# Postgres from docker-compose.yml — host port is 5435 (mapped to container 5432).
DATABASE_URL=postgresql://postgres:password@localhost:5435/tge_dev

# Dev port. Every dev consumer (admin BFF proxy, qa scripts, health probes)
# expects the API on :4000 — main.ts otherwise defaults to 3333.
PORT=4000

# QA-only escape hatch — bypasses ThrottlerGuard so the 5/min auth bucket
# doesn't kill long browser walkthroughs. validateEnv refuses to boot in prod
# with this set. Uncomment when running e2e/QA passes.
# DEV_AUTH_THROTTLE_DISABLED=1

# Global ThrottlerGuard baseline (requests/min/IP, default 60). Prod-safe knob:
# raise it if consumer-app SSR starts 429ing — all SSR fetches from one app
# instance share that instance's egress IP against this one bucket. Per-route
# @Throttle limits (login 5/min, etc.) are unaffected.
# THROTTLE_GLOBAL_LIMIT=60

# ─── Permanent feature flags ──────────────────────────────────────────────
# Read through FeatureFlagsService — never via ConfigService directly. Both
# default to "feature on"; set to 1 to opt out.
#
# EMAIL_VERIFICATION_DISABLED=1 — Academy self-service signup auto-verifies
#   the new account, skips the verification email, and returns tokens directly.
#   Useful without a working Resend domain or for QA passes that hit /register
#   repeatedly. Keep apps/{admin,academy} NEXT_PUBLIC_EMAIL_VERIFICATION_DISABLED
#   in sync.
EMAIL_VERIFICATION_DISABLED=1
#
# GOOGLE_AUTH_DISABLED=1 — /auth/google* and /academy/auth/google* return 501
#   regardless of GOOGLE_CLIENT_ID. Pair with NEXT_PUBLIC_GOOGLE_AUTH_DISABLED
#   on each frontend so the UI hides the Google button.
GOOGLE_AUTH_DISABLED=1

# JWT secrets — dev placeholders. In prod use: openssl rand -base64 48
JWT_ADMIN_ACCESS_SECRET=dev_admin_access_secret_change_in_production_xx
JWT_ADMIN_REFRESH_SECRET=dev_admin_refresh_secret_change_in_production_x
JWT_ACADEMY_ACCESS_SECRET=dev_academy_access_secret_change_in_production
JWT_ACADEMY_REFRESH_SECRET=dev_academy_refresh_secret_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Comma-separated allowlist. Boot fails fast on an empty value in production.
CORS_ORIGINS=http://localhost:3050,http://localhost:3051,http://localhost:3052,http://localhost:3053

STORAGE_TYPE=local

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_URL=http://localhost:4000/api/v1
MAX_FILE_SIZE=10485760

# Admin URL — invitation email links + OAuth redirects target this.
ADMIN_PUBLIC_URL=http://localhost:3051

# Invitation flow. Resend runs in sandbox mode until we own a sending domain;
# `onboarding@resend.dev` only delivers to the email on your Resend account.
# Paste a re_… key to enable real sends; leave blank to log emails to stdout.
RESEND_API_KEY=
EMAIL_FROM=TGE Dev <onboarding@resend.dev>
# Inbox(es) that receive the admin alert on a new inquiry (comma-separated).
# Unset = admin alert path stays silent; the submitter still gets a confirmation.
# INQUIRIES_NOTIFY_TO=ops@tge.com,ops@reveria.com
# openssl rand -base64 48   (≥32 chars required in prod)
INVITATION_TOKEN_SECRET=dev_invitation_token_secret_replace_in_production_xxxxxx

# Google OAuth — leave blank until the GCP project is wired up (the admin UI
# hides the Google button and /auth/google returns 501 without these).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Resend webhook signing secret (for /webhooks/resend). Blank in dev rejects
# all webhook traffic with 503.
RESEND_WEBHOOK_SECRET=

# Prometheus scrape bearer token. If unset, /api/v1/metrics 404s.
METRICS_BEARER_TOKEN=

# Sentry error reporting. Blank in dev = Sentry init skips.
# SENTRY_DSN=
# Performance trace sample rate (0..1). Defaults to 0.1 when unset.
SENTRY_TRACES_RATE=

# Windows-only workaround: the default library engine's .dll.node gets locked
# by other Node processes during `prisma generate`. The binary engine sidesteps
# the lock. LEAVE THIS UNSET on macOS/Linux — the default engine works there.
# PRISMA_CLIENT_ENGINE_TYPE=binary

ACADEMY_ORIGIN=http://localhost:3053
ACADEMY_PUBLIC_URL=http://localhost:3053

# ─── CRM listing sync (REBS) ──────────────────────────────────────────────
# Paste your key here to validate the live feed locally (`pnpm rebs:validate`)
# or to run the sync against a dev DB. The sync only runs when REBS_SYNC_ENABLED=1
# AND a key is set. REBS_BASE_URL points at the demo instance by default — safe
# to read without our production key. Switch to the client instance for the real
# feed: https://client-396fe343.crmrebs.com/api/public
REBS_API_KEY=
REBS_BASE_URL=https://demo.crmrebs.com/api/public
REBS_SYNC_ENABLED=0
