generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum PropertyType {
  apartment
  house
  villa
  terrain
  penthouse
  estate
  chalet
  mansion
  palace
}

enum PropertyStatus {
  available
  sold
  reserved
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AGENT
}

enum AdminUserStatus {
  ACTIVE
  SUSPENDED
}

/// Identity-pool discriminator. Two values: `admin` (back-office +
/// catalog-agent users — managed via /people/team and /people/agents)
/// and `academy` (study-platform students). Same value already lives in
/// JWT payloads as the `realm` claim; this column makes it a first-class
/// schema concept so post-fusion (Phase 2) the unified `users` table can
/// be queried without application-layer filtering.
///
/// Stage 2.0a (additive): added with table-specific defaults so existing
/// rows backfill correctly. AdminUser → 'admin', AcademyUser → 'academy'.
/// Agents stay in the admin realm via their AdminUser link; no separate
/// 'agent' value.
enum Realm {
  admin
  academy
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  BOUNCED
}

enum OAuthProvider {
  GOOGLE
}

enum InquiryType {
  general
  property
  developer
  // viewing — user wants to schedule an in-person visit; tracked separately
  // so agents can filter the queue by intent. Added 2026-05-10 (M-4 in the
  // contact-flow audit closed the client/server type drift).
  viewing
  // valuation — user wants their own property assessed; lead funnel for the
  // listing-acquisition side rather than the buyer-acquisition side.
  valuation
}

enum InquiryStatus {
  new
  read
  archived
}

enum Furnishing {
  unfurnished
  semi_furnished
  furnished
  luxury
}

enum ConstructionMaterial {
  brick
  concrete
  bca
  wood
  stone
  mixed
}

enum PropertyCondition {
  new_build
  renovated
  good
  needs_renovation
  under_construction
}

enum SellerType {
  private_seller
  agency
  developer
}

enum RateType {
  fixed
  variable
  govt_program
}

enum HeatingType {
  central_gas
  centralized
  block_central
  electric
  heat_pump
  solid_fuel
  none
}

enum OwnershipType {
  personal
  company
  mixed
}

enum WindowType {
  pvc_double
  pvc_triple
  wood
  aluminum
  mixed
}

enum PropertyTier {
  luxury
  affordable
}

// ─── Admin ───────────────────────────────────────────────

model AdminUser {
  id           String          @id @default(uuid())
  email        String          @unique
  // Nullable because SSO-only users (e.g. Google) have no local password.
  // Invitation-based onboarding creates the row with this field NULL when the
  // agent accepts via Google; the password path sets a bcrypt hash here.
  passwordHash String?         @map("password_hash")
  name         String
  role         AdminRole       @default(EDITOR)
  // Lifecycle state. SUSPENDED blocks login + refresh (existing access tokens
  // expire within JWT_ACCESS_EXPIRATION, default 15 min). disabledAt anchors
  // the suspension event; cleared on reactivate. Soft-disable preserves audit
  // history that hard-delete would orphan.
  status       AdminUserStatus @default(ACTIVE)
  disabledAt   DateTime?       @map("disabled_at")
  // Login activity. lastLoginAt is stamped on every successful auth (password
  // or Google). lastSeenAt is touched lazily on authenticated requests to
  // distinguish dormant accounts from active ones.
  lastLoginAt  DateTime?       @map("last_login_at")
  lastSeenAt   DateTime?       @map("last_seen_at")
  // Phase 2 — Stage 2.0a (additive). Identity-pool discriminator that
  // mirrors the `realm` JWT claim. Always 'admin' for rows in this
  // table; the column exists so the future unified `users` table can
  // partition without app-layer filtering. See `phase-2-schema-fusion.md`.
  realm        Realm           @default(admin)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Reverse relations
  agent                     Agent?               @relation("AdminUserAgent")
  auditLogs                 AuditLog[]           @relation("AuditLogActor")
  identities                OAuthIdentity[]
  createdInvitations        Invitation[]         @relation("InvitationInviter")
  passwordResetTokens       PasswordResetToken[]
  searchHistory             AdminSearchHistory[]
  // Phase 2 — Stage 2.0c. Cross-realm FKs formalised. Existing
  // service code uses these as bare string references; no behaviour
  // change beyond DB-level integrity (SetNull on AdminUser delete).
  grantedAcademyEnrollments AcademyEnrollment[]  @relation("AcademyEnrollmentGranter")
  uploadedLessonAttachments LessonAttachment[]   @relation("LessonAttachmentUploader")
  createdAcademyInvitations AcademyInvitation[]  @relation("AcademyInvitationInviter")

  @@index([status])
  @@index([realm])
  @@map("admin_users")
}

/// Per-admin recent-search history. Populated when a user selects an entity
/// from the unified ⌘K palette, surfaced as the empty-state "Recent" section
/// next time they open it. Capped at 25 rows per user (oldest dropped in a
/// follow-up delete after each upsert) — small enough that bouncing through
/// the table to render the recent list is index-only.
///
/// `entity` is stored as a plain string (mirrors the `SearchEntityType` enum
/// in `@tge/types/schemas/search`) so adding a new entity type to global
/// search doesn't require a Prisma migration. The history controller
/// re-validates the value against the user's role on read so a demotion
/// between sessions can't leak rows the caller is no longer allowed to see.
model AdminSearchHistory {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity     String
  entityId   String    @map("entity_id")
  title      String
  subtitle   String?
  href       String
  imageUrl   String?   @map("image_url")
  badge      String?
  selectedAt DateTime  @default(now()) @map("selected_at")

  @@unique([userId, entity, entityId])
  @@index([userId, selectedAt(sort: Desc)])
  @@map("admin_search_history")
}

// ─── Invitation ──────────────────────────────────────────

/// Time-limited invitation for onboarding a new AdminUser (typically AGENT).
/// `tokenHash` stores a sha256 of the plaintext token sent by email — the
/// plaintext never hits the DB. One PENDING invitation per Agent at a time
/// (unique `agentId`); resending regenerates the token and extends expiry.
model Invitation {
  id                 String           @id @default(uuid())
  email              String
  tokenHash          String           @unique @map("token_hash")
  role               AdminRole
  // Display name for non-AGENT invitations. AGENT invites derive the name
  // from the linked Agent (firstName + lastName), so this stays NULL for
  // those rows. Required at the controller level for non-AGENT roles.
  name               String?
  agentId            String?          @unique @map("agent_id")
  agent              Agent?           @relation("AgentInvitation", fields: [agentId], references: [id], onDelete: Cascade)
  status             InvitationStatus @default(PENDING)
  expiresAt          DateTime         @map("expires_at")
  acceptedAt         DateTime?        @map("accepted_at")
  acceptedVia        String?          @map("accepted_via") // "password" | "google"
  // Email send / bounce telemetry. `resendEmailId` is the Resend message id
  // surfaced on successful send; webhook handlers correlate bounces +
  // complaints by this. `bouncedAt`/`bounceReason` mirror what Resend
  // reports so the admin UI can show "Bounced \u2014 hard" vs "\u2014 soft".
  emailSentAt        DateTime?        @map("email_sent_at")
  emailAttempts      Int              @default(0) @map("email_attempts")
  emailLastAttemptAt DateTime?        @map("email_last_attempt_at")
  resendEmailId      String?          @map("resend_email_id")
  bouncedAt          DateTime?        @map("bounced_at")
  bounceReason       String?          @map("bounce_reason")
  reminderSentAt     DateTime?        @map("reminder_sent_at")
  invitedById        String?          @map("invited_by_id")
  invitedBy          AdminUser?       @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([email, status])
  @@index([status, expiresAt])
  @@index([status, emailSentAt])
  @@index([resendEmailId])
  @@map("invitations")
}

// ─── Revoked Token ───────────────────────────────────────

/// Refresh-token denylist. On logout, user delete, or forced sign-out the
/// token's `jti` claim is inserted here. The refresh strategy rejects any
/// token whose jti matches. Rows are garbage-collected daily once past the
/// refresh-token expiry window.
model RevokedToken {
  jti         String   @id
  adminUserId String   @map("admin_user_id")
  revokedAt   DateTime @default(now()) @map("revoked_at")
  reason      String // 'logout' | 'user_deleted' | 'forced'

  @@index([adminUserId])
  @@index([revokedAt])
  @@map("revoked_tokens")
}

// ─── Password Reset ──────────────────────────────────────

/// Self-serve password reset token. Same token discipline as Invitation
/// (plaintext never persisted; only the sha256 hash), but scoped to
/// AdminUsers who already have a passwordHash set. SSO-only users recover
/// via Google's own account flow \u2014 they're out of scope here.
model PasswordResetToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")
  adminUserId String    @map("admin_user_id")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── OAuth Identity ──────────────────────────────────────

/// Federated login identity linking an AdminUser to an external provider
/// account. Lookup shape is `(provider, providerAccountId)` unique. An
/// AdminUser may have 0 or more identities; deleting the user cascades.
model OAuthIdentity {
  id                String        @id @default(uuid())
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  adminUserId       String        @map("admin_user_id")
  adminUser         AdminUser     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  email             String
  createdAt         DateTime      @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([adminUserId])
  @@map("oauth_identities")
}

// ─── Property ────────────────────────────────────────────

model Property {
  id               String         @id @default(uuid())
  slug             String         @unique
  title            Json // LocalizedString {en, ro}
  description      Json // LocalizedString
  shortDescription Json           @map("short_description") // LocalizedString
  price            Float
  currency         String         @default("EUR")
  type             PropertyType
  status           PropertyStatus @default(available)
  tier             PropertyTier   @default(luxury)

  // Location (flattened).
  /// @deprecated Read via `cityRef.name` — remove 2026-Q3 once no callers.
  city         String
  /// @deprecated Read via `cityRef.slug` — remove 2026-Q3 once no callers.
  citySlug     String  @map("city_slug")
  /// @deprecated Filter via `cityRef.county.slug`; column stays for now.
  countySlug   String? @map("county_slug")
  /// @deprecated Read via `neighborhoodRef.name` — remove 2026-Q3 once no callers.
  neighborhood String
  address      Json // LocalizedString
  latitude     Float
  longitude    Float

  // Specs (flattened)
  bedrooms  Int
  bathrooms Int
  area      Float
  landArea  Float?   @map("land_area")
  floors    Int
  floor     Int? // Which floor the unit is on (apartments)
  yearBuilt Int      @map("year_built")
  garage    Int?
  pool      Boolean? @default(false)

  // Advanced classification
  furnishing Furnishing?
  material   ConstructionMaterial?
  condition  PropertyCondition?
  sellerType SellerType?           @map("seller_type")

  // Storia-style classification
  heating          HeatingType?
  ownership        OwnershipType?
  windowType       WindowType?    @map("window_type")
  availabilityDate DateTime?      @map("availability_date")

  // Amenity flags
  hasBalcony           Boolean @default(false) @map("has_balcony")
  hasTerrace           Boolean @default(false) @map("has_terrace")
  hasParking           Boolean @default(false) @map("has_parking")
  hasGarage            Boolean @default(false) @map("has_garage")
  hasSeparateKitchen   Boolean @default(false) @map("has_separate_kitchen")
  hasStorage           Boolean @default(false) @map("has_storage")
  hasElevator          Boolean @default(false) @map("has_elevator")
  hasInteriorStaircase Boolean @default(false) @map("has_interior_staircase")

  // Appliances (Facilități)
  hasWashingMachine Boolean @default(false) @map("has_washing_machine")
  hasFridge         Boolean @default(false) @map("has_fridge")
  hasStove          Boolean @default(false) @map("has_stove")
  hasOven           Boolean @default(false) @map("has_oven")
  hasAC             Boolean @default(false) @map("has_ac")

  // Security (Siguranță)
  hasBlinds       Boolean @default(false) @map("has_blinds")
  hasArmoredDoors Boolean @default(false) @map("has_armored_doors")
  hasIntercom     Boolean @default(false) @map("has_intercom")

  // Media
  hasInternet Boolean @default(false) @map("has_internet")
  hasCableTV  Boolean @default(false) @map("has_cable_tv")

  // Features as JSON array of LocalizedString[]
  features Json @default("[]")

  featured Boolean @default(false)
  isNew    Boolean @default(false) @map("is_new")

  // Unpublished draft of localized fields. Shape:
  // { title: LocalizedString, description: LocalizedString,
  //   shortDescription: LocalizedString, address: LocalizedString }
  draft Json?

  // ── CRM sync provenance (CRM-agnostic) ──────────────────
  // `source` names the originating adapter ('rebs' | null = native/admin).
  // `externalId` is that adapter's stable id (REBS internal_id, stringified).
  // The composite unique is the upsert key; both nullable so native rows
  // (source = null) are never constrained and two CRMs can share an id value.
  source           String?   // 'rebs' | null
  externalId       String?   @map("external_id")
  // CRM's own last-modified timestamp — drives change detection and the
  // media re-download gate. Distinct from `updatedAt` (our row's mtime).
  sourceModifiedAt DateTime? @map("source_modified_at")
  // Ingestion state, ORTHOGONAL to the commercial `status` enum. Set when the
  // feed drops a listing (per-item 404 or absent-from-walk) or when an import
  // is quarantined (unknown city). Public reads filter `unpublishedAt IS NULL`;
  // admin sees everything. Sync never touches `status`/`tier` — those stay
  // human-owned after the first insert.
  unpublishedAt    DateTime? @map("unpublished_at")
  // Imported RO-only content was mirrored into `en`; flags rows a later
  // (deferred) translation pass should backfill. Native rows stay false.
  needsTranslation Boolean   @default(false) @map("needs_translation")

  // Relations
  developerId String?    @map("developer_id")
  developer   Developer? @relation(fields: [developerId], references: [id], onDelete: SetNull)
  agentId     String?    @map("agent_id")
  agent       Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)

  // Location FKs. Nullable during transition — denormalized city/citySlug/
  // neighborhood strings above remain the source of truth for reads until the
  // consumer code is migrated to use cityRef/neighborhoodRef.
  cityId          String?       @map("city_id")
  cityRef         City?         @relation(fields: [cityId], references: [id], onDelete: SetNull)
  neighborhoodId  String?       @map("neighborhood_id")
  neighborhoodRef Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  images    PropertyImage[]
  inquiries Inquiry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([citySlug])
  @@index([countySlug])
  @@index([type])
  @@index([status])
  @@index([price])
  @@index([featured])
  @@index([agentId])
  @@index([furnishing])
  @@index([material])
  @@index([condition])
  @@index([sellerType])
  @@index([floor])
  @@index([heating])
  @@index([ownership])
  @@index([availabilityDate])
  @@index([latitude, longitude])
  @@index([cityId])
  @@index([neighborhoodId])
  @@index([tier])
  @@index([developerId])
  @@index([tier, featured, createdAt(sort: Desc)])
  // Hot listing path: every query now starts with a server-enforced tier
  // filter (see SiteMiddleware). These composites cover the two dominant
  // filter shapes from properties.service: price-range-by-city and the
  // bedrooms/bathrooms/area sliders on the search page.
  @@index([tier, citySlug, price])
  @@index([tier, bedrooms, bathrooms, area])
  // Upsert key for CRM-sourced listings; both columns nullable (native rows
  // are unconstrained — Postgres treats NULLs as distinct in a unique index).
  @@unique([source, externalId], name: "source_external_id")
  @@index([source])
  @@index([unpublishedAt])
  @@map("properties")
}

model PropertyImage {
  id        String  @id @default(uuid())
  src       String
  alt       Json // LocalizedString
  isHero    Boolean @default(false) @map("is_hero")
  sortOrder Int     @default(0) @map("sort_order")

  // CRM-sync bookkeeping. `sourceUrl` is the original (forbidden-to-hotlink)
  // CRM image URL — the dedupe key: a sync re-downloads only when the URL
  // changes. `storageKey` is the R2/local object key, kept so cleanup can call
  // storage.delete() directly without re-deriving the key from `src`. Both
  // null for admin-uploaded images.
  sourceUrl  String? @map("source_url")
  storageKey String? @map("storage_key")

  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([propertyId, sourceUrl])
  @@map("property_images")
}

// ─── Developer ───────────────────────────────────────────

model Developer {
  id               String  @id @default(uuid())
  slug             String  @unique
  name             String
  logo             String
  description      Json // LocalizedString
  shortDescription Json    @map("short_description") // LocalizedString
  city             String
  citySlug         String  @map("city_slug")
  website          String?
  projectCount     Int     @default(0) @map("project_count")
  featured         Boolean @default(false)
  coverImage       String? @map("cover_image")
  tagline          Json? // LocalizedString

  // Unpublished draft of localized fields. Shape:
  // { description: LocalizedString, shortDescription: LocalizedString }
  draft Json?

  properties Property[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("developers")
}

// ─── Agent ───────────────────────────────────────────────

model Agent {
  id        String  @id @default(uuid())
  slug      String  @unique
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  email     String  @unique
  phone     String
  photo     String?
  bio       Json // LocalizedString {en, ro}
  active    Boolean @default(true)

  // Optional login link — populated when an AdminUser has role AGENT linked
  // to this sales-agent record. SetNull on delete preserves the public-facing
  // agent record even if the login is removed.
  adminUserId String?    @unique @map("admin_user_id")
  adminUser   AdminUser? @relation("AdminUserAgent", fields: [adminUserId], references: [id], onDelete: SetNull)

  // Optional pending/past invitation for onboarding the agent's login account.
  // Unique on Invitation.agentId enforces at most one per agent at a time.
  invitation Invitation? @relation("AgentInvitation")

  properties Property[]

  // Unpublished draft of localized fields. Shape: { bio: LocalizedString }
  draft Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agents")
}

// ─── County ──────────────────────────────────────────────

model County {
  id            String @id @default(uuid())
  name          String @unique
  slug          String @unique
  code          String @unique // ISO 3166-2:RO code, e.g. "CJ", "B", "TM"
  latitude      Float
  longitude     Float
  propertyCount Int    @default(0) @map("property_count")

  cities City[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("counties")
}

// ─── City ────────────────────────────────────────────────

model City {
  id            String @id @default(uuid())
  // Slug stays globally unique — frontend routes `/cities/[slug]` assume
  // one slug == one city. Names, however, are only unique within a county
  // (Romanian counties can share city names, e.g. "Albești" in multiple
  // județe).
  name          String
  slug          String @unique
  description   Json // LocalizedString
  image         String
  propertyCount Int    @default(0) @map("property_count")
  latitude      Float?
  longitude     Float?

  // countyId is required — seed + admin UI both enforce it, and a city
  // without a county is meaningless for search / SEO / breadcrumbs.
  // Restrict on delete: can't remove a county while cities still point at it.
  countyId String @map("county_id")
  county   County @relation(fields: [countyId], references: [id], onDelete: Restrict)

  // Unpublished draft of localized fields. Shape: { description: LocalizedString }
  draft Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  neighborhoods Neighborhood[]
  properties    Property[]
  brands        CityBrand[]

  @@unique([name, countyId])
  @@index([countyId])
  @@map("cities")
}

// ─── Brand membership (M2N) ──────────────────────────────
//
// Each City / County can be tagged with one or more Brand values. Tags
// drive per-brand visibility on public sites and per-brand admin filtering.
// A row's *absence* in the join table means "not visible to that brand"
// (replaces the legacy SiteConfig.tgeCountyScope allowlist + tgeHiddenCities
// denylist + hardcoded REVERY_HIDDEN_CITY_SLUGS pattern).

enum Brand {
  tge
  revery
}

model CityBrand {
  cityId String @map("city_id")
  brand  Brand
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([cityId, brand])
  @@index([brand])
  @@map("city_brands")
}

// ─── Neighborhood ────────────────────────────────────────

model Neighborhood {
  id     String @id @default(uuid())
  name   String
  slug   String
  cityId String @map("city_id")
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  properties Property[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([slug, cityId])
  @@index([cityId])
  @@map("neighborhoods")
}

// ─── Testimonial ─────────────────────────────────────────

model Testimonial {
  id           String @id @default(uuid())
  clientName   String @map("client_name")
  location     String
  propertyType String @map("property_type")
  quote        Json // LocalizedString
  rating       Int    @default(5)

  // Unpublished draft of localized fields. Shape: { quote: LocalizedString }
  draft Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ─── Inquiry ────────────────────────────────────────────

model Inquiry {
  id     String        @id @default(uuid())
  type   InquiryType   @default(general)
  status InquiryStatus @default(new)

  name    String
  email   String
  phone   String?
  message String  @db.Text

  entityName String? @map("entity_name")
  entitySlug String? @map("entity_slug")

  budget       String?
  propertySlug String? @map("property_slug")

  // Implicit relation to Property via propertySlug ↔ Property.slug (both unique).
  // No new FK column — Prisma resolves at query time. Enables AGENT scoping:
  // `where: { property: { agentId: user.agentId } }`.
  property Property? @relation(fields: [propertySlug], references: [slug])

  // Brand + surface that originated the inquiry. `source` is the brand-derived
  // tag (e.g. "revery-contact", "tge-property-detail") stamped by the shared
  // `useInquirySubmission` hook; `sourceUrl` is the full URL of the submitting
  // page so admins can jump back to context. Both nullable for pre-existing
  // rows. See Article.source/sourceUrl for the pattern precedent.
  source    String? @db.VarChar(120)
  sourceUrl String? @map("source_url") @db.VarChar(500)

  // GDPR Art.7 consent record. `consentedAt` is the server-stamped timestamp
  // of when the user ticked the required privacy checkbox; `gdprConsentVersion`
  // is the policy version they agreed to (so we can prove what was shown to
  // them at submission time). Both nullable for legacy rows that pre-date the
  // checkbox. `marketingConsent` is a separate optional opt-in for promotional
  // emails — must be unticked by default per GDPR.
  gdprConsentVersion String?   @map("gdpr_consent_version") @db.VarChar(40)
  marketingConsent   Boolean   @default(false) @map("marketing_consent")
  consentedAt        DateTime? @map("consented_at")

  // Brand isolation primitive. Stamped server-side from `req.site.id` at
  // create time so admin queries can scope to a single brand without trusting
  // the client-set `source` string. Nullable for legacy rows; the migration
  // backfills from `source` with a tge fallback for unknown patterns. App is
  // the originating surface (landing | revery | academy) so a unified queue
  // can show "where did this come from" at a glance — useful once academy
  // adds its support form (C-1).
  siteId String? @map("site_id") @db.VarChar(20)
  app    String? @map("app") @db.VarChar(20)

  // Submitter's UI locale at submission time. Captured by the client (the
  // `useInquirySubmission` hook reads `useLocale()` from next-intl) so that
  // confirmation emails are sent in the correct language and admins replying
  // to old inquiries know which language to use. Falls back to a sourceUrl
  // regex derivation when the client didn't send it (rolling-deploy window);
  // PR 4c will tighten this to NOT NULL once the soak is done. Nullable
  // initially so the migration's backfill can complete safely.
  locale String? @default("ro") @db.VarChar(8)

  // Soft-delete. DELETE flips this timestamp instead of dropping the row;
  // reads filter `deletedAt: null` by default. A 90-day cron purges rows
  // beyond that window for GDPR right-to-erasure compliance.
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@index([propertySlug])
  @@index([siteId])
  @@index([deletedAt])
  @@map("inquiries")
}

// ─── Article ─────────────────────────────────────────────

enum ArticleStatus {
  draft
  published
}

model Article {
  id              String        @id @default(uuid())
  slug            String        @unique
  title           Json // LocalizedString
  excerpt         Json // LocalizedString
  content         Json // LocalizedString (markdown)
  coverImage      String        @map("cover_image")
  category        String // guide, news, market-report
  tags            Json          @default("[]") // string[]
  status          ArticleStatus @default(draft)
  publishedAt     DateTime?     @map("published_at")
  authorName      String        @map("author_name")
  authorAvatar    String?       @map("author_avatar")
  readTimeMinutes Int           @default(5) @map("read_time_minutes")

  // Unpublished draft of localized fields, when the editor has saved but not
  // yet published. Promoted into title/excerpt/content + cleared on publish.
  // Shape: { title: LocalizedString, excerpt: LocalizedString, content: LocalizedString }
  draft Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@map("articles")
}

// ─── Bank Rate ───────────────────────────────────────────

model BankRate {
  id            String   @id @default(uuid())
  bankName      String   @map("bank_name")
  rate          Float
  rateType      RateType @map("rate_type")
  maxLtv        Float?   @map("max_ltv")
  maxTermYears  Int?     @map("max_term_years")
  processingFee Float?   @map("processing_fee")
  insuranceRate Float?   @map("insurance_rate")
  notes         String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([rateType])
  @@map("bank_rates")
}

// ─── Financial Indicator ─────────────────────────────────

model FinancialIndicator {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Float
  source    String
  sourceUrl String?  @map("source_url")
  fetchedAt DateTime @map("fetched_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("financial_indicators")
}

// ─── Site Config (singleton) ─────────────────────────────

model SiteConfig {
  id          String @id @default("singleton")
  name        String
  tagline     Json // LocalizedString
  description Json // LocalizedString
  contact     Json // {phone, email, whatsapp?}
  socialLinks Json   @map("social_links") // SocialLink[]

  // Ordered slug lists driving the home-page "featured cities" section on each
  // brand. Per-brand visibility is enforced separately by `city_brands`; these
  // arrays only dictate ORDER for cities already tagged for the brand. Empty
  // array falls back to the default alphabetical list so an unconfigured env
  // never blanks the section. Position in the array IS the rank — admin
  // reorder is an array swap.
  tgeHomepageCities    String[] @default([]) @map("tge_homepage_cities")
  reveryHomepageCities String[] @default([]) @map("revery_homepage_cities")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

// ─── Audit Log ───────────────────────────────────────────

/// Append-only record of mutating admin actions (POST/PATCH/DELETE). Written
/// by the global AuditInterceptor after a successful handler. Forensics
/// columns (requestId, ipHash, userAgent, method, url, status, brand) are
/// populated from the per-request CLS context. `diff` is a precomputed
/// field-level patch so the admin UI can render changed-field chips without
/// re-walking the full before/after snapshots. `retainUntil` powers the
/// retention pruner; null means "keep until ops decides".
model AuditLog {
  id          String     @id @default(uuid())
  actorId     String?    @map("actor_id")
  actor       AdminUser? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String // "property.update", "inquiry.status-change", …
  resource    String // "Property" | "Inquiry" | "Article" | "AdminUser"
  resourceId  String     @map("resource_id")
  before      Json?
  after       Json?
  diff        Json?
  requestId   String?    @map("request_id")
  ipHash      String?    @map("ip_hash") // sha256(ip + AUDIT_IP_PEPPER); never the raw IP (GDPR)
  userAgent   String?    @map("user_agent") @db.Text
  method      String?    @db.VarChar(10)
  url         String?    @db.Text
  status      Int?
  brand       String?    @db.VarChar(32) // SiteId value: TGE_LUXURY | REVERY | ADMIN | UNKNOWN
  retainUntil DateTime?  @map("retain_until")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([resource, createdAt])
  @@index([createdAt])
  @@index([brand, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

// ─── Academy ─────────────────────────────────────────────
//
// Academy is a sibling product to admin/landing/revery. Students live in
// their own AcademyUser table — an email may coincide with an AdminUser by
// design (separate pools, per product decision). Tokens issued by the
// academy auth surface carry `realm: 'academy'` in the JWT payload; admin
// tokens carry `realm: 'admin'`. Guards dispatch on realm.

enum CourseStatus {
  draft
  published
  archived
}

enum LessonType {
  text
  video
}

enum LessonStatus {
  draft
  published
  archived
}

/// Course access dimension, orthogonal to CourseStatus. `enrolled` = listing +
/// lesson access require a matching AcademyEnrollment row (wildcard or
/// per-course). `public` = any authenticated academy user may list and open the
/// course without an enrollment. Default `enrolled` keeps pre-existing rows
/// behaving as they did before the column was introduced.
enum CourseVisibility {
  public
  enrolled
}

model AcademyUser {
  id              String    @id @default(uuid())
  email           String    @unique
  // Nullable for SSO-only accounts (mirror AdminUser.passwordHash).
  passwordHash    String?   @map("password_hash")
  name            String
  // Preferred UI locale, e.g. "ro" | "en" | "fr" | "de". Null → defaultLocale.
  locale          String?
  // Set when a user clicks the email verification link after self-registration,
  // or immediately on Google signup (Google email is pre-verified). Null until
  // then — the verifyEmail flow gates token issuance + wildcard enrollment on
  // this column.
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  // Soft-disable. When set: login returns 403 SUSPENDED, the JWT
  // strategy rejects access tokens, and refresh tokens issued before
  // `tokensRevokedAt` are rejected as well. Reactivating clears
  // `suspendedAt` but keeps `tokensRevokedAt` so old tokens stay
  // invalid until the user logs back in.
  suspendedAt     DateTime? @map("suspended_at")
  suspendedReason String?   @map("suspended_reason")
  // Wall-clock cutoff for token validity. Any access/refresh token
  // whose `iat` is before this timestamp is treated as revoked. Set
  // by suspend(), preserved across reactivate() so a previously
  // suspended user can't reuse old tokens after reinstatement.
  tokensRevokedAt DateTime? @map("tokens_revoked_at")
  // Phase 2 — Stage 2.0a (additive). Always 'academy' for rows in
  // this table. See AdminUser.realm for the rationale and
  // `phase-2-schema-fusion.md` for the full plan.
  realm           Realm     @default(academy)

  identities         AcademyUserIdentity[]
  enrollments        AcademyEnrollment[]
  invitations        AcademyInvitation[]             @relation("AcademyInvitationAcceptedUser")
  resetTokens        AcademyPasswordResetToken[]
  verificationTokens AcademyEmailVerificationToken[]
  lessonProgress     LessonProgress[]

  @@index([suspendedAt])
  @@index([realm])
  @@map("academy_users")
}

/// Federated login identity linking an AcademyUser to an external provider.
/// Shape matches OAuthIdentity but scoped to the academy user pool — a single
/// Google account can exist in both pools independently.
model AcademyUserIdentity {
  id                String        @id @default(uuid())
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  userId            String        @map("user_id")
  user              AcademyUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  email             String
  emailVerified     Boolean       @default(false) @map("email_verified")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("academy_user_identities")
}

/// Time-limited invitation to onboard a new AcademyUser. Mirrors Invitation
/// discipline: plaintext token never persisted, only the sha256 hash.
/// `invitedById` points at the AdminUser (editor+) who issued the invite.
model AcademyInvitation {
  id                 String           @id @default(uuid())
  email              String
  tokenHash          String           @unique @map("token_hash")
  status             InvitationStatus @default(PENDING)
  expiresAt          DateTime         @map("expires_at")
  acceptedAt         DateTime?        @map("accepted_at")
  acceptedVia        String?          @map("accepted_via") // "password" | "google"
  acceptedUserId     String?          @map("accepted_user_id")
  acceptedUser       AcademyUser?     @relation("AcademyInvitationAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)
  // Initial course enrollment granted on acceptance. Null = wildcard "all
  // current + future courses", same semantics as AcademyEnrollment.courseId.
  initialCourseId    String?          @map("initial_course_id")
  initialCourse      Course?          @relation("AcademyInvitationInitialCourse", fields: [initialCourseId], references: [id], onDelete: SetNull)
  invitedById        String?          @map("invited_by_id")
  // Phase 2 — Stage 2.0c. FK formalisation of a previously-uncoupled
  // cross-realm reference. SetNull on AdminUser delete preserves the
  // invitation row + its acceptance history (matches the existing
  // Invitation.invitedById semantics).
  invitedBy          AdminUser?       @relation("AcademyInvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  emailSentAt        DateTime?        @map("email_sent_at")
  emailAttempts      Int              @default(0) @map("email_attempts")
  emailLastAttemptAt DateTime?        @map("email_last_attempt_at")
  resendEmailId      String?          @map("resend_email_id")
  bouncedAt          DateTime?        @map("bounced_at")
  bounceReason       String?          @map("bounce_reason")
  // Set by the hourly reminder cron after sending the 24h-expiry warning email;
  // ensures each invitation receives at most one reminder.
  reminderSentAt     DateTime?        @map("reminder_sent_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([email, status])
  @@index([status, expiresAt])
  @@index([invitedById])
  @@map("academy_invitations")
}

/// Email-verification tokens issued during self-service registration. Parallel
/// shape to AcademyPasswordResetToken: plaintext never persisted, only sha256
/// hash; one-shot via atomic updateMany(usedAt IS NULL).
model AcademyEmailVerificationToken {
  id        String      @id @default(uuid())
  tokenHash String      @unique @map("token_hash")
  userId    String      @map("user_id")
  user      AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Snapshot of the email at send time; if the user later changes their email,
  // existing tokens remain tied to the address they were issued for.
  email     String
  expiresAt DateTime    @map("expires_at")
  usedAt    DateTime?   @map("used_at")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("academy_email_verification_tokens")
}

/// Self-serve password reset for AcademyUsers with a passwordHash set.
/// SSO-only users recover via Google.
model AcademyPasswordResetToken {
  id        String      @id @default(uuid())
  tokenHash String      @unique @map("token_hash")
  userId    String      @map("user_id")
  user      AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime    @map("expires_at")
  usedAt    DateTime?   @map("used_at")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("academy_password_reset_tokens")
}

/// Refresh-token denylist for the academy realm. Parallel to RevokedToken so
/// admin + academy token spaces stay independent.
model AcademyRevokedToken {
  jti       String   @id
  userId    String   @map("user_id")
  revokedAt DateTime @default(now()) @map("revoked_at")
  reason    String // 'logout' | 'user_deleted' | 'forced' | 'enrollment_revoked'

  @@index([userId])
  @@index([revokedAt])
  @@map("academy_revoked_tokens")
}

model Course {
  id          String           @id @default(uuid())
  slug        String           @unique
  title       Json // LocalizedString {ro, en, fr?, de?}
  description Json // LocalizedString
  coverImage  String?          @map("cover_image")
  status      CourseStatus     @default(draft)
  visibility  CourseVisibility @default(enrolled)
  // Sparse ordering (10, 20, 30…) so inserts/reorders don't rewrite every row.
  order       Int              @default(0)
  publishedAt DateTime?        @map("published_at")
  // Unpublished draft of localized fields. Shape:
  // { title: LocalizedString, description: LocalizedString }
  draft       Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  lessons            Lesson[]
  enrollments        AcademyEnrollment[]
  pendingInvitations AcademyInvitation[] @relation("AcademyInvitationInitialCourse")

  @@index([status])
  @@index([order])
  @@index([visibility, status])
  @@map("courses")
}

model Lesson {
  id                   String       @id @default(uuid())
  courseId             String       @map("course_id")
  course               Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug                 String
  // Sparse ordering within the course (10, 20, 30…).
  order                Int
  title                Json // LocalizedString
  excerpt              Json // LocalizedString
  content              Json // LocalizedString (markdown source; rendered HTML served by API)
  type                 LessonType   @default(text)
  videoUrl             String?      @map("video_url")
  // Watching time for video lessons, in seconds. Nullable for drafts and
  // until an oEmbed scrape fills it in. Text lessons leave this NULL —
  // reading time is computed from content at read time, never persisted.
  videoDurationSeconds Int?         @map("video_duration_seconds")
  status               LessonStatus @default(draft)
  publishedAt          DateTime?    @map("published_at")
  // Unpublished draft of localized fields. Shape:
  // { title: LocalizedString, excerpt: LocalizedString, content: LocalizedString }
  draft                Json?
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  progress    LessonProgress[]
  attachments LessonAttachment[]

  @@unique([courseId, slug])
  @@index([courseId, order])
  @@index([status])
  @@map("lessons")
}

/// Files attached to a lesson — handouts, slide decks, exercise zips.
/// Storage is delegated to UploadsService (R2 in prod, local in dev).
/// `uploadedById` references AdminUser cross-realm without an FK
/// (mirrors AcademyEnrollment.grantedById) — tooling that follows FKs
/// won't see this link, but the convention is documented.
model LessonAttachment {
  id           String   @id @default(uuid())
  lessonId     String   @map("lesson_id")
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  // Storage key (R2 object key OR local path under /uploads). The
  // service derives a download URL on read; storage prefix is
  // `academy/lessons/<lessonId>/attachments` so lifecycle policies
  // and cost attribution can target academy assets cleanly.
  storagePath  String   @map("storage_path")
  // Sparse-int ordering within the lesson, mirrors Lesson.order. Default
  // 0 makes the first attachment uploaded sort first; admin reorder
  // rewrites these to dense (0, 10, 20, …) on save.
  sortOrder    Int      @default(0) @map("sort_order")
  uploadedById String?  @map("uploaded_by_id")
  // Phase 2 — Stage 2.0c. FK formalisation; see AcademyInvitation.invitedBy.
  uploadedBy   AdminUser? @relation("LessonAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([lessonId, sortOrder])
  @@map("lesson_attachments")
}

/// Per-student lesson state. `startedAt` is stamped on first read;
/// `lastSeenAt` bumps on every subsequent GET; `completedAt` is set by
/// the explicit "Marchează ca terminată" action and is idempotent (first
/// write wins). Dashboard progress bars + the `Continuă` CTA are both
/// derived from this table — the Course model has no denormalised
/// counters, so drift is impossible.
model LessonProgress {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  user        AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String      @map("lesson_id")
  lesson      Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  startedAt   DateTime    @default(now()) @map("started_at")
  completedAt DateTime?   @map("completed_at")
  lastSeenAt  DateTime    @default(now()) @map("last_seen_at")

  @@unique([userId, lessonId])
  @@index([userId, completedAt])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@map("academy_lesson_progress")
}

/// Grants an AcademyUser access to academy content. `courseId` nullable:
/// NULL courseId = wildcard "all current + future courses". Per-course access
/// is expressed as a non-null row. `grantedById` references AdminUser (no FK
/// — cross-surface); NULL means the row was created by the self-service
/// registration flow (no admin grantor). `revokedAt` soft-deletes.
model AcademyEnrollment {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  user        AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String?     @map("course_id")
  course      Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  // NULL = self-service signup (open-catalog registration). Admin-granted rows
  // MUST populate this column — the invitations + enrollments services enforce
  // that invariant.
  grantedById String?     @map("granted_by_id")
  // Phase 2 — Stage 2.0c. FK formalisation; see AcademyInvitation.invitedBy.
  grantedBy   AdminUser?  @relation("AcademyEnrollmentGranter", fields: [grantedById], references: [id], onDelete: SetNull)
  enrolledAt  DateTime    @default(now()) @map("enrolled_at")
  revokedAt   DateTime?   @map("revoked_at")

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([userId, revokedAt])
  @@map("academy_enrollments")
}
