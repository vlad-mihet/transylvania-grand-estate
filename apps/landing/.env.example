# Copy to `.env.local` (gitignored) and adjust for your environment.
#
# The api-client falls back to http://localhost:3333/api/v1 when this is unset
# (`packages/api-client/src/client.ts`), but the API runs on port 4000 in dev
# per `apps/api/.env`. Without this var set, every SSR fetch from landing
# attempts a connection-refused on :3333 and pages render empty.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
