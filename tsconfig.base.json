{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@tge/types": ["packages/types/src/index.ts"],
      "@tge/types/*": ["packages/types/src/*"],
      "@tge/utils": ["packages/utils/src/index.ts"],
      "@tge/utils/*": ["packages/utils/src/*"],
      "@tge/hooks": ["packages/hooks/src/index.ts"],
      "@tge/hooks/*": ["packages/hooks/src/*"],
      "@tge/ui": ["packages/ui/src/index.ts"],
      "@tge/ui/*": ["packages/ui/src/*"],
      "@tge/i18n": ["packages/i18n/src/index.ts"],
      "@tge/i18n/*": ["packages/i18n/src/*"],
      "@tge/data": ["packages/data/src/index.ts"],
      "@tge/data/*": ["packages/data/src/*"],
      "@tge/tailwind-config": ["packages/tailwind-config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "out"]
}
